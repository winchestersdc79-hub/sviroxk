{
  "expo": {
    "name": "Sviroxk",
    "slug": "sviroxk",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sviroxk",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D1F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sviroxk.productivity"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0D0D1F"
      },
      "package": "com.sviroxk.productivity",
      "versionCode": 3,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://sviroxk.app"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e0169532-2b59-4408-9db1-91b5a1259d57"
      },
      "router": {
        "origin": "https://sviroxk.app"
      }
    },
    "owner": "bibo-07sw-79sp"
  }
}
